# Culturalbility Environment Variables
# Copy this file to .env and fill in your real API keys
# NEVER commit .env to GitHub!

# ============================================
# AI Services (China-Compatible)
# ============================================

# DeepSeek V3 (Primary LLM)
# Get API key: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Kimi / Moonshot AI (Complex reasoning fallback)
# Get API key: https://platform.moonshot.cn
KIMI_API_KEY=your_kimi_api_key_here

# iFlytek (Speech-to-Text + TTS + Pronunciation)
# Get API key: https://www.xfyun.cn
IFLYTEK_APP_ID=your_iflytek_app_id
IFLYTEK_API_KEY=your_iflytek_api_key
IFLYTEK_API_SECRET=your_iflytek_api_secret

# Azure China (TTS backup via 21Vianet)
# Get API key: https://www.azure.cn
AZURE_CHINA_KEY=your_azure_china_key
AZURE_CHINA_REGION=chinaeast2

# Alibaba Cloud (STT fallback)
# Get API key: https://www.aliyun.com/product/nls
ALIYUN_ACCESS_KEY_ID=your_aliyun_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_key_secret

# ============================================
# Cloud Infrastructure (China)
# ============================================

# Aliyun OSS (File storage)
ALIYUN_OSS_BUCKET=your_bucket_name
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# Aliyun CloudMonitor (Monitoring)
ALIYUN_CM_PROJECT=your_project_name

# ============================================
# iOS App Configuration
# ============================================

# Apple Sign-In
APPLE_TEAM_ID=your_team_id
APPLE_BUNDLE_ID=com.yourcompany.culturalbility

# RevenueCat (In-app purchases - if used)
REVENUECAT_API_KEY=your_revenuecat_key

# ============================================
# Backend/Database
# ============================================

# Firebase (if using Firebase China or international)
FIREBASE_API_KEY=your_firebase_key
FIREBASE_PROJECT_ID=your_project_id

# Or PostgreSQL on Aliyun RDS
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ============================================
# Analytics & Monitoring
# ============================================

# Mixpanel or local analytics
MIXPANEL_TOKEN=your_mixpanel_token

# Sentry (error tracking)
SENTRY_DSN=your_sentry_dsn
